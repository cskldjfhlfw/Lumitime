# Lumitime production environment template
# Copy this file to deploy/.env and fill real values before first launch.

LUMITIME_SERVER_NAME=lumitime.example.com
LUMITIME_SSL_CERTIFICATE=/etc/nginx/certs/fullchain.pem
LUMITIME_SSL_CERTIFICATE_KEY=/etc/nginx/certs/privkey.pem
LUMITIME_CLIENT_MAX_BODY_SIZE=50m
LUMITIME_API_IMAGE=lumitime-api:local
LUMITIME_NGINX_IMAGE=lumitime-nginx:local

LUMITIME_DATA_DIR=/opt/lumitime/data
LUMITIME_BACKUP_DIR=/opt/lumitime/backups
LUMITIME_CERT_DIR=/opt/lumitime/certs
LUMITIME_UPLOAD_DIR=/var/lib/lumitime/uploads

POSTGRES_DB=lumitime
POSTGRES_USER=lumitime
POSTGRES_PASSWORD=change-me-now
LUMITIME_DATABASE_URL=postgresql+psycopg://lumitime:change-me-now@db:5432/lumitime

LUMITIME_SECRET_KEY=change-me-to-a-long-random-secret
LUMITIME_CORS_ORIGINS=https://lumitime.example.com
LUMITIME_BOOTSTRAP_TOKEN=change-me-temporarily-for-initial-admin-bootstrap
LUMITIME_ENABLE_INLINE_WORKER=1
LUMITIME_LOG_SUBMIT_MODE=dry_run

BACKUP_RETENTION_DAYS=14
